@using Biblioteca_de_Clase
@model WebApp.Models.CrearActivoViewModel

@{
    ViewData["Title"] = "Crear Nuevo Activo";
}

<h2>Crear Nuevo Activo</h2>
<p>Asociando a la cuenta <strong>ID: @Model.CuentaId</strong> de <strong>@Model.NombrePersona</strong></p>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="CrearActivo" asp-controller="Administrador" method="post">
            <input type="hidden" name="Cedula" value="@Model.Cedula" />
            <input type="hidden" name="CuentaId" value="@Model.CuentaId" />
            <input type="hidden" name="NombrePersona" value="@Model.NombrePersona" />

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Nombre del Activo:</label>
                <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Tipo de Activo:</label>
                <select name="TipoActivo" class="form-select" required>
                    <option value="@TipoActivo.PC">PC</option>
                    <option value="@TipoActivo.SERVER">SERVER</option>
                    <option value="@TipoActivo.MOVIL">MOVIL</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Nivel de Criticidad (1 al 5):</label>
                <input type="number" name="Criticidad" class="form-control" min="1" max="5" value="@Model.Criticidad" required />
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" name="Backup" id="backup" value="true" />
                <label class="form-check-label fw-bold" for="backup">Tiene backup</label>
                <input type="hidden" name="Backup" value="false" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success">Guardar Activo</button>
                <a asp-action="ActivosCuenta" asp-route-cedula="@Model.Cedula" asp-route-cuentaId="@Model.CuentaId" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
