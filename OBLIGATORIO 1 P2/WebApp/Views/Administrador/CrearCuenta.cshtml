@model WebApp.Models.CrearCuentaViewModel

@{
    ViewData["Title"] = "Crear Nueva Cuenta";
}

<h2>Crear Cuenta para @Model.NombrePersona</h2>
<p><strong>Cedula del Propietario:</strong> @Model.Cedula</p>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="CrearCuenta" asp-controller="Administrador" method="post">
            <input type="hidden" name="Cedula" value="@Model.Cedula" />
            <input type="hidden" name="NombrePersona" value="@Model.NombrePersona" />

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" name="Mfa" id="mfa" value="true" />
                <label class="form-check-label" for="mfa">Habilitar MFA</label>
                <input type="hidden" name="Mfa" value="false" />
            </div>

            <button type="submit" class="btn btn-success">Guardar Cuenta</button>
            <a asp-action="Cuentas" asp-route-cedula="@Model.Cedula" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
