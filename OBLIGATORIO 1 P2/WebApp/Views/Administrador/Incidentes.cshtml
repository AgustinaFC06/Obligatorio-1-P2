@model IEnumerable<WebApp.Models.IncidenteListadoViewModel>

@{
    ViewData["Title"] = "Listado de Incidentes";

    bool tieneElementos = false;
    if (Model != null)
    {
        foreach (WebApp.Models.IncidenteListadoViewModel inc in Model)
        {
            tieneElementos = true;
            break;
        }
    }
}

<h2>Listado de Incidentes del Sistema</h2>
<p class="text-muted">Ordenados de mayor a menor segun severidad.</p>

@if (Model == null || !tieneElementos)
{
    <div class="alert alert-info">
        No se registran incidentes en el sistema actualmente.
    </div>
}
else
{
    <table class="table table-striped table-hover mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Codigo de Activo</th>
                <th>Severidad</th>
            </tr>
        </thead>
        <tbody>
            @foreach (WebApp.Models.IncidenteListadoViewModel inc in Model)
            {
                <tr>
                    <td>@inc.Id</td>
                    <td>@inc.FechaReporte.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@inc.Estado</td>
                    <td>@inc.CodigoActivo</td>
                    <td>@inc.Severidad</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-4">
    <a asp-controller="Administrador" asp-action="Personas" class="btn btn-secondary">
        Volver al Inicio
    </a>
</div>
