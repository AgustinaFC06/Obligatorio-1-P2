<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Gestión de Incidentes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column" style="min-height: 100vh;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GestiónSegura</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
                        @* 1. MENU EXCLUSIVO PARA ADMINISTRADORES *@
                        @if (Context.Session.GetString("UsuarioRol") == "ADMIN")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="ListaActivos">Ver Activos</a>
                            </li>
                        }
    
                        @* 2. MENU EXCLUSIVO PARA OPERARIOS *@
                        else if (Context.Session.GetString("UsuarioRol") == "OPERADOR")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Operador" asp-action="ReportarIncidente">Reportar Incidente</a>
                            </li>
                        }
    
                        @* 3. MENU PÚBLICO: Si NO hay ningún usuario en sesión, mostramos botones de entrada *@
                        else
                        {
                            <li class="nav-item ms-auto">
                                <a class="nav-link text-dark" href="/Anonimo/Login">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Anonimo/Registro">Registrarme</a>
                            </li>
                        }

                        @* 4. Muestra el saludo si está logueado *@
                        @if (Context.Session.GetString("UsuarioEmail") != null)
                        {
                            <li class="nav-item ms-auto d-flex align-items-center">
                                <span class="navbar-text me-3 text-secondary">
                                     @Context.Session.GetString("UsuarioEmail")
                                </span>
                                <a class="btn btn-outline-danger btn-sm" asp-controller="Anonimo" asp-action="Logout">Cerrar Sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @* Acá es donde se va a renderizar el cuerpo de cada vista particular *@
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-auto">
        <div class="container text-center">
            &copy; 2026 - Sistema de Ciberseguridad - Obligatorio Programación 2
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
