@using Biblioteca_de_Clase
@model IEnumerable<Activo>

@{
    ViewData["Title"] = "Mis Activos";

    bool tieneActivos = false;
    if (Model != null)
    {
        foreach (Activo activo in Model)
        {
            tieneActivos = true;
            break;
        }
    }
}

<h2>Mis Activos</h2>

@if (Model == null || !tieneActivos)
{
    <div class="alert alert-info">
        No tenes activos asociados.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Codigo</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Criticidad</th>
                <th>Backup</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Activo activo in Model)
            {
                <tr>
                    <td>@activo.CrearAlfanumerico()</td>
                    <td>@activo.Nombre</td>
                    <td>@activo.TipoActivo</td>
                    <td>@activo.Criticidad</td>
                    <td>@(activo.Backup ? "Si" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}
